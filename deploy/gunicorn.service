[Unit]
Description=DV Solutions ERP Gunicorn
After=network.target postgresql.service

[Service]
User=dvsolutions
Group=www-data
WorkingDirectory=/opt/dvsolutions/repo
EnvironmentFile=/opt/dvsolutions/repo/.env.production
ExecStart=/opt/dvsolutions/repo/venv/bin/gunicorn --workers 3 --timeout 120 --bind unix:/run/dvsolutions.sock config.wsgi:application
Restart=always
RestartSec=5
RuntimeDirectory=dvsolutions

[Install]
WantedBy=multi-user.target
